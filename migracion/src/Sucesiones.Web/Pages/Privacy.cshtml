@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacidad";
}

<section class="mx-auto max-w-[720px]">
    <div class="eyebrow eyebrow--accent">Aviso</div>
    <h1 class="mt-3 text-[44px] leading-[1.04] tracking-[-0.005em]">Privacidad</h1>

    <p class="mt-4 text-[16px] text-tinta-suave leading-[1.6]">
        Esta es una interfaz pública en construcción para consultar el Registro de Juicios Universales de la Suprema
        Corte de Justicia de la provincia de Buenos Aires. <strong>No se almacenan datos personales</strong> ni se
        utilizan cookies de seguimiento.
    </p>
    <p class="mt-3 text-[16px] text-tinta-suave leading-[1.6]">
        Las búsquedas se procesan en el servidor y se reenvían al sistema oficial. El texto completo de esta política
        se completa en un slice futuro.
    </p>
</section>
