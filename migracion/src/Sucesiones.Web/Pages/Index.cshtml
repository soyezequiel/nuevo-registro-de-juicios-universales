@page
@using Sucesiones.Web.Componentes
@model IndexModel
@{
    ViewData["Title"] = "Buscar en el Registro de Juicios Universales";
}

<section class="mb-2">
    <div class="eyebrow eyebrow--accent">Consulta pública · Sucesiones</div>
    <h1 class="mt-3 text-[44px] leading-[1.04] tracking-[-0.005em] text-tinta">
        Buscar en el Registro de <em class="italic">Juicios&nbsp;Universales</em>
    </h1>
    <p class="mt-2 max-w-[720px] text-[16.5px] italic text-tinta-suave leading-[1.55]">
        Consulta de actuaciones registradas. Para obtener resultados precisos, complete al menos el apellido del causante
        o el número de oficio. Los datos provienen del sistema oficial de la Suprema Corte de Justicia.
    </p>
</section>

<component type="typeof(PanelBusqueda)" render-mode="ServerPrerendered" />
