<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sucesiones</title>
    <link rel="stylesheet" href="~/css/salida.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-neutral-50 text-marca-negro antialiased">
    <header class="bg-marca-negro text-white shadow">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
            <a class="flex items-center gap-3 text-lg font-semibold tracking-tight" asp-area="" asp-page="/Index">
                <span class="inline-block h-3 w-3 rounded-full bg-marca-azul-claro"></span>
                Sucesiones — Registro de Juicios Universales
            </a>
            <nav class="flex items-center gap-6 text-sm">
                <a class="text-neutral-300 hover:text-white" asp-area="" asp-page="/Index">Inicio</a>
                <a class="text-neutral-300 hover:text-white" asp-area="" asp-page="/Privacy">Privacidad</a>
            </nav>
        </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-10">
        @RenderBody()
    </main>

    <footer class="mt-16 border-t border-neutral-200 bg-white">
        <div class="mx-auto max-w-6xl px-6 py-4 text-xs text-neutral-500">
            &copy; 2026 — Proyecto de rediseño RJU. No afiliado oficialmente a SCBA.
        </div>
    </footer>

    <script src="_framework/blazor.server.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
