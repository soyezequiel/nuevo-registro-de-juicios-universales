@*
    _Layout.cshtml — shell institucional del Registro de Juicios Universales.

    Estructura:
      • Franja slate (techo institucional) — 5px
      • Header oficial: img de wwwroot/img/header-rju.jpg, contenida a 1280
      • Hairline gris
      • MetaBar (breadcrumb + fecha)
      • <main> con max-w-[1120px] y padding generoso
      • Footer sobrio sobre papel-hondo

    Mantengo Razor + Tailwind v4 utilities (sin Node). Las clases custom
    (input-underline, btn-primario, eyebrow, tabla-rju, link-ver) están
    definidas en wwwroot/css/entrada.css.
*@
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Registro de Juicios Universales</title>
    <link rel="stylesheet" href="~/css/salida.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-papel-suave text-tinta antialiased">

    <header>
        @* Franja slate — techo institucional, ancho completo *@
        <div class="h-[5px] bg-[#5b6573]"></div>

        @* Logo oficial — JPEG real del Poder Judicial *@
        <div class="bg-white">
            <div class="mx-auto max-w-[1280px]">
                <a asp-area="" asp-page="/Index" class="block">
                    <img src="~/img/header-rju.jpg"
                         alt="Poder Judicial de la provincia de Buenos Aires — Registro de Juicios Universales"
                         class="block w-full h-auto max-h-[148px]" />
                </a>
            </div>
        </div>

        @* Hairline + meta bar (breadcrumb + fecha) *@
        <div class="border-b border-regla-suave bg-papel-suave">
            <div class="mx-auto max-w-[1120px] px-4 sm:px-6 lg:px-8 py-2.5 flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between text-[12.5px] text-tinta-tenue">
                <nav class="flex flex-wrap items-baseline gap-2.5" aria-label="Breadcrumb">
                    <a asp-area="" asp-page="/Index"
                       class="eyebrow hover:text-tinta-suave">Inicio</a>
                    <span class="text-tinta-fina">›</span>
                    <span class="eyebrow">Consulta pública</span>
                    <span class="text-tinta-fina">›</span>
                    <span class="eyebrow font-semibold text-tinta-suave">Sucesiones</span>
                </nav>
                <div class="flex flex-wrap items-baseline gap-x-5 gap-y-1">
                    <a asp-area="" asp-page="/Privacy" class="eyebrow hover:text-tinta-suave">Privacidad</a>
                    <span class="eyebrow">@DateTime.Now.ToString("d 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-AR"))</span>
                </div>
            </div>
        </div>
    </header>

    <main class="mx-auto max-w-[1120px] px-4 sm:px-6 lg:px-8 py-8 sm:py-10 lg:py-12">
        @RenderBody()
    </main>

    <footer class="mt-16 border-t border-regla bg-papel-hondo">
        <div class="mx-auto max-w-[1120px] px-4 sm:px-6 lg:px-8 py-6 grid grid-cols-1 sm:grid-cols-[auto_1fr] lg:grid-cols-[auto_1fr_auto] gap-4 sm:gap-6 items-start sm:items-center">
            <div class="text-tinta-tenue">
                @* Pequeño marca-shield tipográfico — § §  *@
                <span class="font-display text-2xl text-tinta-fina">§</span>
            </div>
            <div class="text-[12px] text-tinta-tenue leading-relaxed">
                <div class="eyebrow text-tinta-suave">Suprema Corte de Justicia · provincia de Buenos Aires</div>
                <div class="mt-0.5">Calle 13 e/ 47 y 48 · La Plata · República Argentina</div>
            </div>
            <div class="flex flex-wrap gap-x-6 gap-y-2 items-baseline text-[12px] text-tinta-tenue sm:col-span-2 lg:col-span-1">
                <a class="hover:text-tinta-suave" href="https://github.com/soyezequiel" target="_blank" rel="noopener">GitHub</a>
                <a class="hover:text-tinta-suave" href="https://www.linkedin.com/in/ezequiel-alcayaga/" target="_blank" rel="noopener">LinkedIn</a>
                <a class="hover:text-tinta-suave" asp-area="" asp-page="/Privacy">Privacidad</a>
            </div>
        </div>
    </footer>

    <script src="_framework/blazor.server.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
