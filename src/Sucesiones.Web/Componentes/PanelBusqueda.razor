@inject IClienteRju Rju

@*
    PanelBusqueda.razor — rediseño institucional (propuesta B · "Sentencia moderna").

    Mismo ADN serif que la propuesta A, pero más amigable y accesible:
      • Inputs en caja con borde tenue + focus ring suave
      • Formulario en tarjeta blanca con secciones (Principales / Variantes)
      • Tabla con header gris cálido y zebra
      • "Ver oficio" como botón outline con icono ojo
      • Visor modal con sidebar de thumbnails de páginas

    La lógica de búsqueda, sesión SCBA, selección y visor de oficio queda
    intacta respecto del slice 5b. Solo cambia presentación.

    Las clases custom (.card-rju, .input-caja, .label-caja, .btn-primario,
    .btn-ghost, .link-ver, .tabla-rju, .eyebrow,
    .spinner-rju) viven en wwwroot/css/entrada.css.
*@

<section class="panel-busqueda">

    @* ── Formulario ───────────────────────────────────────────────────────── *@
    <section class="card-rju p-9 mt-7">
        <div class="flex items-baseline justify-between mb-5 pb-4 border-b border-regla-fina">
            <div>
                <div class="eyebrow eyebrow--accent">Formulario</div>
                <h2 class="mt-1 font-display text-[24px] font-semibold text-tinta m-0">Criterios de la consulta</h2>
            </div>
            <div class="text-[13px] text-tinta-tenue italic">
                Todos los campos son opcionales — al menos uno es requerido.
            </div>
        </div>

        <form @onsubmit="Buscar" @onsubmit:preventDefault="true">
            @* Campos principales: 4 columnas con spans 1 / 2 *@
            <div class="grid grid-cols-4 gap-x-6 gap-y-5">
                @foreach (var campo in CamposPrincipales)
                {
                    <div class="@(campo.Span == 2 ? "col-span-2" : "col-span-1")">
                        <label class="label-caja" for="@($"campo-{campo.Nombre}")">@campo.Etiqueta</label>
                        <input id="@($"campo-{campo.Nombre}")" type="text"
                               class="input-caja"
                               placeholder="@(campo.Nombre == "RJUfallecimiento" ? "dd/mm/aaaa" : "")"
                               disabled="@(estado == EstadoBusqueda.Cargando)"
                               @bind="valores[campo.Nombre]" />
                    </div>
                }
            </div>

            @* Variantes — sub-sección con borde tenue arriba *@
            <div class="mt-6 pt-5 border-t border-regla-fina">
                <div class="flex items-baseline gap-3 mb-3">
                    <div class="eyebrow">Variantes</div>
                    <span class="text-[12.5px] italic text-tinta-tenue">
                        Para captar grafías alternativas del causante.
                    </span>
                </div>
                <div class="grid grid-cols-2 gap-x-6 gap-y-5">
                    @foreach (var campo in CamposVariantes)
                    {
                        <div>
                            <label class="label-caja" for="@($"campo-{campo.Nombre}")">@campo.Etiqueta</label>
                            <input id="@($"campo-{campo.Nombre}")" type="text"
                                   class="input-caja"
                                   disabled="@(estado == EstadoBusqueda.Cargando)"
                                   @bind="valores[campo.Nombre]" />
                        </div>
                    }
                </div>
            </div>

            @* Acciones *@
            <div class="mt-6 pt-5 border-t border-regla-fina flex justify-end items-center gap-3">
                <button type="button" @onclick="Limpiar"
                        class="btn-ghost"
                        disabled="@(estado == EstadoBusqueda.Cargando)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                        <path d="M3 12a9 9 0 1 0 3-6.7"/><polyline points="3 4 3 9 8 9"/>
                    </svg>
                    Limpiar formulario
                </button>
                <button type="submit"
                        class="btn-primario"
                        disabled="@(estado == EstadoBusqueda.Cargando)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                        <circle cx="11" cy="11" r="6"/><line x1="20" y1="20" x2="15.5" y2="15.5"/>
                    </svg>
                    @(estado == EstadoBusqueda.Cargando ? "Buscando…" : "Buscar en el registro")
                </button>
            </div>
        </form>
    </section>

    @* ── Resultados ───────────────────────────────────────────────────────── *@
    @if (estado != EstadoBusqueda.Inicial)
    {
        <section class="card-rju mt-6 p-0">
            <header class="px-8 py-5 border-b border-regla-fina flex items-baseline justify-between">
                <div>
                    <div class="eyebrow eyebrow--accent">Resultados</div>
                    <h3 class="mt-1 font-display text-[24px] font-semibold text-tinta m-0">
                        <span class="num-tab">@resultados.Count</span> @(resultados.Count == 1 ? "actuación" : "actuaciones")
                    </h3>
                </div>
            </header>

            @if (estado == EstadoBusqueda.ConResultados)
            {
                <table class="tabla-rju">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Año</th>
                            <th>Oficio</th>
                            <th>Apellido y nombre</th>
                            <th class="t-right">Documento</th>
                            <th class="t-right">Fallecimiento</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fila in resultados)
                        {
                            <tr>
                                <td class="text-tinta-fina num">@(fila.Indice + 1)</td>
                                <td class="num text-tinta-suave">@fila.Anio</td>
                                <td class="num mono">@fila.NumOficio</td>
                                <td class="text-tinta font-semibold">
                                    @fila.Apellido, <span class="font-normal">@fila.Nombre</span>
                                </td>
                                <td class="t-right num mono">@fila.NumDocumento</td>
                                <td class="t-right num text-tinta-suave">@(string.IsNullOrEmpty(fila.Fallecimiento) ? "—" : fila.Fallecimiento)</td>
                                <td class="t-right" style="padding-right: 24px;">
                                    <button type="button" @onclick="() => Seleccionar(fila)"
                                            class="link-ver"
                                            disabled="@(estadoVisor == EstadoVisor.Cargando)">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                                            <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="2.5"/>
                                        </svg>
                                        Ver oficio
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @* Estados sin tabla — cargando / sin resultados / error *@
            @if (estado == EstadoBusqueda.Cargando)
            {
                <div class="px-8 py-16 text-center">
                    <svg viewBox="0 0 40 40" width="40" height="40" class="spinner-rju mx-auto mb-3">
                        <circle cx="20" cy="20" r="16" fill="none" stroke="currentColor" stroke-opacity="0.18" stroke-width="2.4" />
                        <path d="M20 4 a16 16 0 0 1 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
                    </svg>
                    <div class="font-display text-[20px] text-tinta-suave font-semibold mb-1">Consultando el registro…</div>
                    <div class="text-[14px] text-tinta-tenue">Esto puede tardar unos segundos. No cierre la ventana.</div>
                </div>
            }
            else if (estado == EstadoBusqueda.SinResultados)
            {
                <div class="px-8 py-16 text-center">
                    <div class="mx-auto mb-3 w-14 h-14 rounded-full bg-azul-tinte text-marca-azul flex items-center justify-center">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                            <circle cx="12" cy="12" r="9"/><line x1="12" y1="11" x2="12" y2="16"/><circle cx="12" cy="8" r="0.6" fill="currentColor"/>
                        </svg>
                    </div>
                    <div class="font-display text-[20px] text-tinta font-semibold mb-1">No se encontraron actuaciones</div>
                    <div class="text-[14.5px] text-tinta-tenue max-w-[420px] mx-auto leading-[1.55]">
                        No hay registros que coincidan con los criterios ingresados. Revisá la ortografía o probá con menos campos.
                    </div>
                </div>
            }
            else if (estado == EstadoBusqueda.Error)
            {
                <div class="px-8 py-16 text-center">
                    <div class="mx-auto mb-3 w-14 h-14 rounded-full bg-vino-tinte text-vino flex items-center justify-center">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                            <path d="M12 3 2 21h20z"/><line x1="12" y1="10" x2="12" y2="14"/><circle cx="12" cy="17.5" r="0.6" fill="currentColor"/>
                        </svg>
                    </div>
                    <div class="font-display text-[20px] text-vino font-semibold mb-1">No pudimos completar la consulta</div>
                    <div class="text-[14.5px] text-tinta-tenue max-w-[420px] mx-auto leading-[1.55]">
                        El sistema oficial no respondió. Reintentá en unos instantes; si el problema persiste, contactá a Mesa de ayuda.
                    </div>
                </div>
            }
        </section>
    }

    @* ── Visor de oficio (modal con sidebar de thumbnails) ────────────────── *@
    @if (estadoVisor != EstadoVisor.Oculto)
    {
        <div class="visor-modal fixed inset-0 z-50 flex items-start justify-center bg-[rgba(20,18,14,0.55)] p-6 pt-14"
             @onclick="CerrarVisor">
            <div class="bg-white rounded-md shadow-[0_30px_80px_rgba(20,18,14,0.4)] w-full max-w-[980px] grid grid-rows-[auto_1fr] overflow-hidden max-h-[calc(100vh-100px)]"
                 style="grid-template-columns: 300px 1fr;"
                 @onclick:stopPropagation="true">

                @* Header (atraviesa las dos columnas) *@
                <header class="col-span-2 px-7 py-4 border-b border-regla-fina bg-papel-suave grid grid-cols-[1fr_auto] gap-5">
                    <div>
                        <div class="eyebrow eyebrow--accent">Oficio · Sucesión</div>
                        <div class="mt-1 font-display text-[22px] font-semibold text-tinta">
                            @filaSeleccionada?.Apellido, <span class="font-normal">@filaSeleccionada?.Nombre</span>
                        </div>
                        <div class="mt-1 text-[13px] text-tinta-tenue">
                            Oficio <b class="text-tinta-suave font-semibold">@filaSeleccionada?.NumOficio/@filaSeleccionada?.Anio</b>
                            @if (!string.IsNullOrEmpty(filaSeleccionada?.Fallecimiento))
                            {
                                <text> · Fallecimiento <b class="text-tinta-suave font-semibold">@filaSeleccionada.Fallecimiento</b></text>
                            }
                            @if (!string.IsNullOrEmpty(filaSeleccionada?.NumDocumento))
                            {
                                <text> · D.N.I. <b class="text-tinta-suave font-semibold">@filaSeleccionada.NumDocumento</b></text>
                            }
                        </div>
                    </div>
                    <div class="flex gap-2 items-center">
                        @if (estadoVisor == EstadoVisor.Listo)
                        {
                            <a href="@($"/oficio/{searchId}/pdf")" download="@nombreArchivoPdf"
                               target="_blank" rel="noopener"
                               class="btn-primario">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                                    <path d="M6 3h9l4 4v14H6z"/><path d="M15 3v4h4"/>
                                </svg>
                                Descargar PDF
                            </a>
                        }
                        <button type="button" @onclick="CerrarVisor"
                                aria-label="Cerrar"
                                class="ml-1 w-9 h-9 bg-white border border-regla rounded-md cursor-pointer text-tinta-suave flex items-center justify-center hover:bg-papel-suave">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                                <line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>
                            </svg>
                        </button>
                    </div>
                </header>

                @* Sidebar de thumbnails *@
                <aside class="p-4 border-r border-regla-fina bg-papel-tarjeta overflow-auto">
                    @if (estadoVisor == EstadoVisor.Listo)
                    {
                        <div class="eyebrow mb-2.5">@cantidadPaginas @(cantidadPaginas == 1 ? "página" : "páginas")</div>
                        <div class="flex flex-col gap-2.5">
                            @for (var i = 0; i < cantidadPaginas; i++)
                            {
                                var pagina = i;
                                <button type="button"
                                        class="@($"text-left p-2 bg-white rounded-sm cursor-pointer flex items-center gap-2 {(pagina == paginaActiva ? "border-2 border-marca-azul" : "border border-regla-suave")}")"
                                        @onclick="() => paginaActiva = pagina">
                                    @* mini-thumb del documento *@
                                    <div class="w-[42px] h-[56px] bg-papel-tarjeta border border-regla-suave flex flex-col p-1 gap-0.5 shrink-0">
                                        <div class="h-[2px] bg-regla"></div>
                                        <div class="h-px bg-regla-suave"></div>
                                        <div class="h-px bg-regla-suave"></div>
                                        <div class="h-px bg-regla-suave"></div>
                                        <div class="flex-1"></div>
                                        <div class="h-px bg-regla-suave self-end w-[60%]"></div>
                                    </div>
                                    <div class="min-w-0">
                                        <div class="@($"text-[12px] font-semibold {(pagina == paginaActiva ? "text-marca-azul" : "text-tinta")}")">
                                            Página @(pagina + 1)
                                        </div>
                                        <div class="text-[11px] text-tinta-tenue mt-0.5">
                                            @(pagina == 0 ? "Carátula" : "Anexo")
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </aside>

                @* Canvas — todas las páginas apiladas (UX igual que SCBA: scroll) *@
                <main class="p-8 bg-papel-hondo overflow-auto">
                    @switch (estadoVisor)
                    {
                        case EstadoVisor.Cargando:
                            <div class="py-16 text-center">
                                <svg viewBox="0 0 40 40" width="40" height="40" class="spinner-rju mx-auto mb-3">
                                    <circle cx="20" cy="20" r="16" fill="none" stroke="currentColor" stroke-opacity="0.18" stroke-width="2.4" />
                                    <path d="M20 4 a16 16 0 0 1 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
                                </svg>
                                <div class="font-display text-[18px] text-tinta-suave font-semibold mb-1">Abriendo el documento en SCBA…</div>
                            </div>
                            break;

                        case EstadoVisor.Error:
                            <p class="py-16 text-center text-vino italic">@mensajeVisor</p>
                            break;

                        case EstadoVisor.Listo:
                            @for (var i = 0; i < cantidadPaginas; i++)
                            {
                                var pagina = i;
                                <figure class="mb-6 last:mb-0">
                                    <figcaption class="eyebrow mb-2">Página @(pagina + 1) de @cantidadPaginas</figcaption>
                                    <div class="bg-white shadow-[0_4px_20px_rgba(0,0,0,0.10),0_0_0_1px_rgba(0,0,0,0.05)]">
                                        <img src="@($"/oficio/{searchId}/pagina/{pagina}?v={visorToken}")"
                                             alt="@($"Página {pagina + 1} del oficio")"
                                             class="mx-auto block max-w-full" />
                                    </div>
                                </figure>
                            }
                            break;
                    }
                </main>
            </div>
        </div>
    }
</section>

@code {
    // Estado del visor de oficio. Propio de la pantalla (no del backend).
    private enum EstadoVisor { Oculto, Cargando, Listo, Error }

    // Campos divididos por grupo para el render (orden y etiquetas en
    // Modelos/CamposSucesiones.cs).
    private IEnumerable<CampoConsulta> CamposPrincipales =>
        CamposSucesiones.Todos.Where(c => c.Grupo == GrupoCampo.Principal);
    private IEnumerable<CampoConsulta> CamposVariantes =>
        CamposSucesiones.Todos.Where(c => c.Grupo == GrupoCampo.Variantes);

    private Dictionary<string, string> valores = new();
    private EstadoBusqueda estado = EstadoBusqueda.Inicial;
    private IReadOnlyList<ResultadoSucesion> resultados = Array.Empty<ResultadoSucesion>();

    private string searchId = "";
    private EstadoVisor estadoVisor = EstadoVisor.Oculto;
    private int cantidadPaginas;
    private string mensajeVisor = "";

    // Página activa en el sidebar del visor — visual; el main muestra todas.
    // Se podría sincronizar con scroll en una iteración futura.
    private int paginaActiva = 0;

    // Token para romper el caché del navegador en el <img> del visor.
    private string visorToken = "";
    private string nombreArchivoPdf = "oficio.pdf";

    // Fila clickeada en la última selección — para el header del modal.
    private ResultadoSucesion? filaSeleccionada;

    protected override void OnInitialized() => CargarCampos();

    private void CargarCampos() =>
        valores = CamposSucesiones.Todos.ToDictionary(c => c.Nombre, _ => string.Empty);

    private void Limpiar()
    {
        CargarCampos();
        estado = EstadoBusqueda.Inicial;
        resultados = Array.Empty<ResultadoSucesion>();
        CerrarVisor();
    }

    private void CerrarVisor()
    {
        estadoVisor = EstadoVisor.Oculto;
        filaSeleccionada = null;
        paginaActiva = 0;
    }

    private async Task Buscar()
    {
        estado = EstadoBusqueda.Cargando;
        resultados = Array.Empty<ResultadoSucesion>();
        CerrarVisor();

        var respuesta = await Rju.BuscarAsync(valores);
        resultados = respuesta.Filas;
        searchId = respuesta.SearchId;
        estado = respuesta.Estado switch
        {
            EstadoConsulta.ConResultados => EstadoBusqueda.ConResultados,
            EstadoConsulta.SinResultados => EstadoBusqueda.SinResultados,
            _ => EstadoBusqueda.Error,
        };
    }

    private async Task Seleccionar(ResultadoSucesion fila)
    {
        filaSeleccionada = fila;
        estadoVisor = EstadoVisor.Cargando;
        paginaActiva = 0;

        var r = await Rju.SeleccionarAsync(searchId, fila.Indice);
        if (r.Ok)
        {
            cantidadPaginas = r.CantidadPaginas;
            visorToken = Guid.NewGuid().ToString("N");
            nombreArchivoPdf = ArmarNombreArchivo(fila);
            estadoVisor = EstadoVisor.Listo;
        }
        else
        {
            mensajeVisor = r.Mensaje ?? "No se pudo abrir el oficio.";
            estadoVisor = EstadoVisor.Error;
        }
    }

    private static string ArmarNombreArchivo(ResultadoSucesion fila)
    {
        var crudo = $"ConsultaRJU_{fila.Apellido}_{fila.Nombre}_{fila.NumDocumento}.pdf";
        var invalidos = System.IO.Path.GetInvalidFileNameChars();
        return new string(crudo.Select(c => invalidos.Contains(c) ? '_' : c).ToArray());
    }
}
