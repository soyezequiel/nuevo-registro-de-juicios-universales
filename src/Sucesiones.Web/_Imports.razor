@*
    [BUSCAR] _Imports.razor es el equivalente de _ViewImports.cshtml pero para
    componentes Blazor (.razor). Las directivas @using acá aplican a todos los
    .razor de este proyecto, así no hay que repetirlas en cada componente.
    La lista de abajo es la estándar de cualquier app Blazor — sale del template
    `dotnet new blazorserver` casi tal cual.
*@
@using System.Net.Http
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Sucesiones.Web
@using Sucesiones.Web.Componentes
